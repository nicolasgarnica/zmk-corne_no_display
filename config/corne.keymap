/*
 * Copyright (c) 2020 The ZMK Contributors
 *
 * SPDX-License-Identifier: MIT
 *
 * Adapted from QMK LAYOUT_split_3x6_3_ex2 keymap.
 * The 4 extra keys (2 per half, between the halves) have been removed
 * to fit the standard 42-key Corne layout.
 *
 * Mouse keys (mkp, mmv, msc) require CONFIG_ZMK_POINTING=y in corne.conf.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

/* ── Extended tapping-term timers ─────────────────────────────────────────── */

/* Mod-tap: Settings to try to reduce accidenta setting off of home row mods */
&mt {
    tapping-term-ms = <280>;
    quick-tap-ms = <175>;
    require-prior-idle-ms = <150>;
    flavor = "balanced";
};

/* Layer-tap: similar with what is setup for mod-tap */
&lt {
    tapping-term-ms = <280>;
    quick-tap-ms = <175>;
    require-prior-idle-ms = <150>;
};

/* ── Mouse / scroll tuning ────────────────────────────────────────────────── */

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&msc {
    acceleration-exponent = <1>;
    time-to-max-speed-ms = <100>;
    delay-ms = <0>;
};

/ {
    behaviors {
        td0: td0 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD0";
            #binding-cells = <0>;
            bindings = <&kp LEFT_SHIFT>, <&kp CAPS>;
        };

        
        /* ── Custom behavior for homerow shift ────────────────────────────────────── */
        hs: homerow_shift {
            // For SHIFT only — snappy, keeps up with fast typing
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <50>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "QWERTY";
            // ─────────────────────────────────────────────────────────────────
            // | ESC  |  Q       |  W       |  E       |  R       |  T       |   |  Y  |  U       |  I       |  O       |  P       |  -       |
            // | TAB  | LGUI/A   | LALT/S   | LSFT/D   | LCTL/F   | NAV/G    |   |  H  | RCTL/J   | RSFT/K   | RALT/L   | RGUI/;   |  '       |
            // | CAPS |  Z       |  X       |  C       |  V       |  B       |   |  N  |  M       |  ,       |  .       |  /       | RA([)    |
            //                              |  TO 1    |  MO 2    |  ENT     |   | SPC | BSPC     | DEL      |

            bindings = <
&kp ESC       &kp Q       &kp W       &kp E        &kp R        &kp T          &kp Y    &kp U        &kp I        &kp O       &kp P          &kp MINUS
&kp TAB       &mt LGUI A  &mt LALT S  &hs LSHFT D  &mt LCTRL F  &lt 1 G        &kp H    &mt RCTRL J  &hs RSHFT K  &mt RALT L  &mt RGUI SEMI  &kp SQT
&kp CAPSLOCK  &kp Z       &kp X       &kp C        &kp V        &kp B          &kp N    &kp M        &kp COMMA    &kp DOT     &kp FSLH       &kp RA(LBKT)
                                       &to 1        &mo 2        &kp ENTER      &kp SPACE  &kp BSPC   &kp DEL
            >;
        };

        lower_layer {
            display-name = "NAV";
            // ─────────────────────────────────────────────────────────────────
            // | &trans | ---      | MBtn2    | M↑       | MBtn1    | MScr↑  |   | PgUp | Home   | Up     | End    | ---   | &trans |
            // | &trans | MScr←    | M←       | M↓       | M→       | MScr→  |   | ---  | Left   | Down   | Right  | ---   | &trans |
            // | &trans | LGUI     | LALT     | LSFT     | LCTL     | M↓     |   | PgDn | RCTL   | RSFT   | RALT   | RGUI  | &trans |
            //                               | TG 3     | TO 0     | ENT    |   | SPC  | &trans | &trans |

            bindings = <
&trans  &none            &mkp RCLK        &mmv MOVE_UP    &mkp LCLK        &msc SCRL_UP      &kp PG_UP  &kp HOME   &kp UP     &kp END    &none     &trans
&trans  &msc SCRL_LEFT   &mmv MOVE_LEFT   &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &msc SCRL_RIGHT   &none      &kp LEFT   &kp DOWN   &kp RIGHT  &none     &trans
&trans  &kp LGUI         &kp LALT         &kp LSHFT       &kp LCTRL        &mmv MOVE_DOWN     &kp PG_DN  &kp RCTRL  &kp RSHFT  &kp RALT   &kp RGUI  &trans
                                           &tog 3          &to 0            &kp ENTER          &kp SPACE  &trans     &trans
            >;
        };

        raise_layer {
            display-name = "SYMBOL";
            // ─────────────────────────────────────────────────────────────────
            // |  `   |  1         |  2         |  3         |  4         |  5   |   |  6   |  7         |  8         |  9         |  0         |  -   |
            // | ---  | LGUI/NUBS  | LALT/'     | LSFT/[     | LCTL/-     | ---  |   | ---  | RCTL/=     | RSFT/]     | RALT/\     | RGUI/INT1  | ---  |
            // | ---  | ---        | ---        | ---        | ---        | ---  |   | ---  | ---        | ---        | ---        | ---        | ---  |
            //                                  | DEL        | &trans     | ENT  |   | SPC  | BSPC       | DEL        |

            bindings = <
&kp GRAVE  &kp N1                  &kp N2          &kp N3          &kp N4          &kp N5       &kp N6  &kp N7          &kp N8          &kp N9          &kp N0           &kp MINUS
&none      &mt LGUI NON_US_BSLH    &mt LALT SQT    &mt LSHFT LBKT  &mt LCTRL MINUS &none        &none   &mt RCTRL EQUAL &mt RSHFT RBKT  &mt RALT BSLH   &mt RGUI INT_YEN &none
&none      &none                   &none           &none           &none           &none        &none   &none           &none           &none           &none            &none
                                                    &kp DEL         &trans          &kp ENTER    &kp SPACE  &kp BSPC     &kp DEL
            >;
        };

        fn_layer {
            display-name = "Fn";
            // ─────────────────────────────────────────────────────────────────
            // | ESC       | F1      | F2      | F3      | F4      | F5       |   | F8      | F9      | F10     | F11     | F12     | BSPC        |
            // | &bt CLR   | HUE+    | SAT+    | BRI+    | SPD+    | ---      |   | ---     | RGB←    | RGB TOG | RGB→    | ---     | &bt CLR     |
            // | BOOT      | HUE-    | SAT-    | BRI-    | SPD-    | ---      |   | ---     | ---     | ---     | ---     | ---     | BOOT        |
            //                                 | &trans  | TO 0    | ENT      |   | SPC     | &trans  | BSPC    |
            //
            // NOTE: QMK CG_SWAP / CG_NORM (Ctrl↔GUI swap) have no direct
            // ZMK equivalent. Use OS-level settings or a combo instead.
            // QMK EE_CLR mapped to &bt BT_CLR (closest useful equivalent).

            bindings = <
&kp ESC      &kp F1           &kp F2           &kp F3           &kp F4           &kp F5             &kp F8   &kp F9           &kp F10          &kp F11          &kp F12  &kp BSPC
&bt BT_CLR   &rgb_ug RGB_HUI  &rgb_ug RGB_SAI  &rgb_ug RGB_BRI  &rgb_ug RGB_SPI  &none              &none    &rgb_ug RGB_EFR  &rgb_ug RGB_TOG  &rgb_ug RGB_EFF  &none    &bt BT_CLR
&bootloader  &rgb_ug RGB_HUD  &rgb_ug RGB_SAD  &rgb_ug RGB_BRD  &rgb_ug RGB_SPD  &none              &none    &none            &none            &none            &none    &bootloader
                                                &trans           &to 0            &kp ENTER          &kp SPACE  &trans         &kp BSPC
            >;
        };
    };
};
